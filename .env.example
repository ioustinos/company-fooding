# Supabase — client-exposed (browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase — server-only (Netlify Functions). Never prefix with VITE_ or expose to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# GonnaOrder — server-only. Login-then-JWT auth (no static API key).
GONNAORDER_API_BASE=https://admin.gonnaorder.com/api/v1
GONNAORDER_USERNAME=
GONNAORDER_PASSWORD=

# CF admin token — gates bootstrap endpoints (e.g. cf-sync-gonnaorder) until
# JWT-based super-admin auth lands (CF-12). Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CF_ADMIN_TOKEN=

# Email — server-only
RESEND_API_KEY=
RESEND_FROM_ADDRESS=no-reply@companyfooding.com

# Top-ups dry-run toggle. True = scheduler logs but doesn't actually call GonnaOrder.
CF_TOPUPS_DRY_RUN=false
